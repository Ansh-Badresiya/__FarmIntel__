# ─────────────────────────────────────────────
#  AgriSubsidyAI – Environment Variables
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://agri_user:agri_pass@localhost:5432/agrisubsidy_db

# ── Security ──────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── PostgreSQL (for Docker Compose) ───────────
POSTGRES_USER=agri_user
POSTGRES_PASSWORD=agri_pass
POSTGRES_DB=agrisubsidy_db

# ── pgAdmin (for Docker Compose) ──────────────
PGADMIN_DEFAULT_EMAIL=admin@agrisubsidy.local
PGADMIN_DEFAULT_PASSWORD=pgadmin_pass

# ── Frontend ───────────────────────────────────
VITE_API_URL=http://localhost:8000
