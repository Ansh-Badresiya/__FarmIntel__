# ─────────────────────────────────────────────
#  FarmIntel – Environment Variables
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://farmintel_user:farmintel_pass@localhost:5432/farmintel_db

# ── Security ──────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── PostgreSQL (for Docker Compose) ───────────
POSTGRES_USER=farmintel_user
POSTGRES_PASSWORD=farmintel_pass
POSTGRES_DB=farmintel_db

# ── pgAdmin (for Docker Compose) ──────────────
PGADMIN_DEFAULT_EMAIL=admin@farmintel.local
PGADMIN_DEFAULT_PASSWORD=pgadmin_pass

# ── Frontend ───────────────────────────────────
VITE_API_URL=http://localhost:8000

